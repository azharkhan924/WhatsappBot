# ============================
# SERVER CONFIG
# ============================
PORT=3000
NODE_ENV=production

# ============================
# AI PROVIDER CONFIG
# Switch provider by changing AI_PROVIDER only.
# Supported now: gemini, groq
# Reserved for future: openai, claude
# ============================
AI_PROVIDER=groq

# Google Gemini (https://aistudio.google.com/app/apikey)
# You can define multiple keys for automatic rotation/failover on rate limits.
# Either use a comma-separated list in GEMINI_API_KEY, or define GEMINI_API_KEY_2, GEMINI_API_KEY_3, etc.
GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_API_KEY_2=your_second_gemini_api_key_here
# GEMINI_API_KEY_3=your_third_gemini_api_key_here
# GEMINI_API_KEY_4=your_fourth_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Groq (https://console.groq.com/keys)
# You can define multiple keys for automatic rotation/failover on rate limits.
# Either use a comma-separated list in GROQ_API_KEY, or define GROQ_API_KEY_2, GROQ_API_KEY_3, etc.
GROQ_API_KEY=your_groq_api_key_here
# GROQ_API_KEY_2=your_second_groq_api_key_here
# GROQ_API_KEY_3=your_third_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Shared AI generation settings
TEMPERATURE=0.7
MAX_TOKENS=512
AI_TIMEOUT_MS=15000
AI_MAX_RETRIES=2

# ============================
# CONVERSATION MEMORY
# ============================
MEMORY_LIMIT=20
MEMORY_TIMEOUT_MINUTES=30

# ============================
# HUMAN-LIKE BEHAVIOUR
# ============================
TYPING_DELAY_MIN_MS=2000
TYPING_DELAY_MAX_MS=5000

# ============================
# SECURITY
# ============================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=30
API_KEY=change_this_to_a_secret_for_rest_api_protection

# ============================
# LOGGING
# ============================
LOG_LEVEL=info

# ============================
# WHATSAPP
# ============================
WA_CLIENT_ID=whatsapp-bot-session
IGNORE_GROUPS=false
