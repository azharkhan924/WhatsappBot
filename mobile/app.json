{
  "expo": {
    "name": "WhatsApp AI Assistant",
    "slug": "whatsapp-ai-control-room",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f172a"
      },
      "package": "com.azharkhan1.whatsappaicontrolroom"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "5a0d46b0-11d7-4ede-a2f8-6beb3145d5d2"
      }
    },
    "plugins": [
      "expo-asset",
      "expo-font"
    ]
  }
}
